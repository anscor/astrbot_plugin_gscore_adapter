{
    "IP": {
        "description": "链接至GsCore的IP地址",
        "type": "string",
        "hint": "默认应为127.0.0.1或localhost",
        "default": "localhost"
    },
    "PORT": {
        "description": "链接至GsCore的端口",
        "type": "string",
        "hint": "默认应为8765",
        "default": "8765"
    },
    "SSL": {
        "description": "是否启用SSL连接GsCore",
        "type": "bool",
        "hint": "默认False，启用后会使用wss协议连接GsCore"
    },
    "BOT_ID": {
        "description": "向GsCore注册自身的Bot",
        "type": "string",
        "hint": "默认应为AstrBot",
        "default": "AstrBot"
    },
    "WS_TOKEN": {
        "description": "连接Core的WsToken",
        "type": "string",
        "hint": "WsToken",
        "default": ""
    },
    "GSCORE_ONLY_PREFIXES": {
        "description": "仅转发到GsCore且拦截AstrBot后续LLM的触发前缀列表",
        "type": "list",
        "hint": "例如: core, gs, sr, zzz, ww，每条输入后回车",
        "default": []
    },
    "MAX_RETRY_TIMES": {
        "description": "GsCore连接断开后的最大重试次数",
        "type": "int",
        "hint": "默认30次，-1为无限重试",
        "default": 30
    }
}